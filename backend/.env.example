LLM_DEFAULT_PROVIDER=modal_glm

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

MODAL_GLM_BASE_URL=https://api.us-west-2.modal.direct/v1
MODAL_GLM_API_KEY=
MODAL_GLM_MODEL=zai-org/GLM-5.1-FP8
MODAL_GLM_DISABLE_THINKING=true

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

REQUEST_TIMEOUT_SECONDS=20
LLM_REQUEST_TIMEOUT_SECONDS=90
AGENT_RUN_TIMEOUT_SECONDS=240
MAX_RETRIES=3
AGENT_MAX_STEPS=6

# Conversation memory (LangGraph checkpointer).
# Если задан — используется AsyncPostgresSaver для персистентного хранения
# истории диалога per session_id. Если пусто — fallback на InMemorySaver
# (state в RAM, теряется при restart, но работает без зависимостей).
#
# Вариант A — локальный Postgres :5432 (без Docker, замени USER на своего):
#   createdb chainlit
# AGENT_CHECKPOINT_POSTGRES_URL=postgresql://USER@localhost:5432/chainlit
# Вариант B — Postgres от Langfuse Docker (:5433):
#   docker compose -f infra/langfuse-compose.yml up -d langfuse-postgres
# AGENT_CHECKPOINT_POSTGRES_URL=postgresql://langfuse:langfuse@localhost:5433/chainlit
AGENT_CHECKPOINT_POSTGRES_URL=

# --- Chainlit data layer (история чатов в sidebar, multi-chat) ---
# CHAINLIT_AUTH_SECRET: секрет для подписи auth-токенов. Сгенерировать:
#   uv run chainlit create-secret
CHAINLIT_AUTH_SECRET=
# DATABASE_URL: Postgres для хранения чатов/сообщений/юзеров. Драйвер asyncpg.
# Перед стартом создай БД + применишь схему:
#   createdb chainlit && psql -d chainlit -f infra/chainlit_schema.sql
# Если DATABASE_URL пуст ИЛИ Postgres недоступен → UI работает без истории
# чатов (graceful degradation, без ошибок).
# Вариант A — локальный Postgres :5432:
# DATABASE_URL=postgresql+asyncpg://USER@localhost:5432/chainlit
# Вариант B — Langfuse Docker :5433:
# DATABASE_URL=postgresql+asyncpg://langfuse:langfuse@localhost:5433/chainlit
DATABASE_URL=
