# --- LLM provider selection ---
# Один из: gemini | openai | modal_glm | ollama
LLM_DEFAULT_PROVIDER=gemini

# --- Gemini (Google AI Studio) ---
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# --- OpenRouter (fallback OpenAI-compatible gateway) ---
# Получите ключ на https://openrouter.ai/workspaces/default/keys
# Используйте когда Google недоступен из-за региона/VPN.
# Бесплатные модели: google/gemma-4-31b-it:free, meta-llama/llama-4-90b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- NVIDIA NIM (вторичный fallback после OpenRouter) ---
# Получите ключ на https://build.nvidia.com (Build with NVIDIA, бесплатно).
# Не зависит от Google → работает когда OpenRouter free pool тоже rate-limited.
# Модели с tool calling: meta/llama-3.3-70b-instruct, mistralai/mixtral-8x22b-instruct-v0.1,
# qwen/qwen2.5-coder-32b-instruct, nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# meta/llama-3.3-70b-instruct — default. Стабильная модель с tool calling.
# z-ai/glm4.7 был снят NVIDIA NIM 2026-05-14 (410 Gone). Альтернативы:
#   nvidia/llama-3.3-nemotron-super-49b-v1 (NVIDIA-tuned, 49B, быстрее)
#   mistralai/mixtral-8x22b-instruct-v0.1 (Mixtral, 8x22B sparse MoE)
#   nvidia/llama-3.1-nemotron-ultra-253b-v1 (253B, мощнее но медленнее)
# Список моделей: curl -H "Authorization: Bearer $NVIDIA_API_KEY" $NVIDIA_BASE_URL/models
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Mistral La Plateforme (третий fallback) ---
# Самый щедрый free tier среди этих провайдеров:
#   60 RPM (1 req/sec), 500K TPM, 1 миллиард токенов/месяц.
# Tool calling нативный + structured output. Получить ключ:
#   https://console.mistral.ai/home?profile_dialog=api-keys
# Модели с function calling (выберите по приоритету):
#   mistral-medium-3.5      — frontier agentic+coding, 262K ctx (default, Apr 2026)
#   magistral-small-latest  — Mistral Small 4, reasoning hybrid, 262K, быстрее
#   mistral-large-latest    — Mistral Large 3, top-tier reasoning, 262K, медленнее
#   ministral-14b-latest    — edge model, 262K, ультра-быстро
#   codestral-latest        — code-specific, 256K
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-medium-3.5

# При true (default) Gemini автоматически переключается на цепочку
# OpenRouter → NVIDIA, если Google вернул ошибку (region block, quota, 5xx).
# Поставь false, чтобы видеть исходные ошибки Gemini для отладки.
LLM_ENABLE_FALLBACK=true
# Per-provider RPM caps (process-wide token bucket). Defaults sit just under
# free-tier limits to absorb clock skew without ever raising 429.
# Google AI Studio: gemini-3-flash-preview≈5, gemma-4-31b-it≈15-30,
#   gemini-3.1-flash-lite-preview≈15.
LLM_RATE_LIMIT_GEMINI_RPM=13
# OpenRouter free pool: 20 RPM per model
# https://openrouter.ai/docs/api/reference/limits
LLM_RATE_LIMIT_OPENROUTER_RPM=18
# NVIDIA NIM (build.nvidia.com): 40 RPM per model
LLM_RATE_LIMIT_NVIDIA_RPM=35
# Mistral La Plateforme: 60 RPM (1 req/sec) free tier
LLM_RATE_LIMIT_MISTRAL_RPM=55

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# --- Modal GLM ---
MODAL_GLM_API_KEY=
MODAL_GLM_BASE_URL=https://api.us-west-2.modal.direct/v1
MODAL_GLM_MODEL=zai-org/GLM-5.1-FP8
MODAL_GLM_DISABLE_THINKING=true

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Langfuse tracing (optional) ---
# Local self-hosted Langfuse: see infra/README.md
#   docker compose -f infra/langfuse-compose.yml up -d
#   open http://localhost:3030 → Sign up → create project → copy keys here
# Cloud option: leave URL as https://cloud.langfuse.com and use cloud keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3030

# --- Agent runtime tuning ---
REQUEST_TIMEOUT_SECONDS=20
LLM_REQUEST_TIMEOUT_SECONDS=120
AGENT_RUN_TIMEOUT_SECONDS=240
AGENT_MAX_STEPS=10
MAX_RETRIES=0
